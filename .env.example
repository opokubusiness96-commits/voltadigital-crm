# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_KEY

# Calendly Webhook (Calendly Admin → Webhooks → erstelltes Signing Key)
CALENDLY_WEBHOOK_SECRET=whsec_...

# Komma-separierte Whitelist der erlaubten Login-Emails (alle anderen werden hart abgelehnt)
AUTHORIZED_EMAILS=hallo@voltadigital.agency,info@jeromederes.com

# Slug der Default-Organisation für eingehende Calendly-Webhooks
# (muss in der organizations-Tabelle existieren)
DEFAULT_ORG_SLUG=jerome
