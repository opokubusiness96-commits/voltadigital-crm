# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_KEY

# Calendly Webhook (Calendly Admin → Webhooks → erstelltes Signing Key)
CALENDLY_WEBHOOK_SECRET=whsec_...

# Komma-separierte Whitelist der erlaubten Login-Emails (alle anderen werden hart abgelehnt)
AUTHORIZED_EMAILS=hallo@voltadigital.agency,info@jeromederes.com

# Slug der Default-Organisation für eingehende Calendly-Webhooks
# (muss in der organizations-Tabelle existieren)
DEFAULT_ORG_SLUG=jerome

# Öffentliche Basis-URL des CRM (für Unsubscribe-Links in Mails)
NEXT_PUBLIC_SITE_URL=https://crm.voltadigital.agency

# ── Brevo Email-Integration (nur Jerome-Org) ──────────────────────────────────
# API-Key: Brevo → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=info@jeromederes.com
BREVO_SENDER_NAME=Jerome Deres Coaching
# Nur diese Org-UUID(s) lösen Mails aus (Default im Code = Jerome). Komma-separiert.
BREVO_ENABLED_ORG_IDS=326f2401-8450-41ad-8f43-0dba76e4a868
# TESTMODUS: solange gesetzt, gehen ALLE Mails (A+B) an diese Inbox statt an Leads.
# Zum Scharfschalten leeren/entfernen.
TEST_EMAIL=deine@inbox.de
# Brevo-Template-IDs (aus Brevo Dashboard bzw. GET /v3/smtp/templates)
BREVO_TPL_FIRST_CONTACT=1
BREVO_TPL_SETTER_CONFIRMATION=2
BREVO_TPL_SETTER_REMINDER_24H=3
BREVO_TPL_SETTER_REMINDER_1H=4
BREVO_TPL_SETTER_FOLLOWUP=5
BREVO_TPL_CLOSER_CONFIRMATION=6
BREVO_TPL_CLOSER_FOLLOWUP=7
BREVO_TPL_WELCOME_ONBOARDING=8
BREVO_TPL_LOST_NURTURE=9
BREVO_TPL_SETTER_NO_SHOW=10
BREVO_TPL_CLOSER_NO_SHOW=11
BREVO_TPL_NUMBER_CHECK=12
BREVO_TPL_CLOSER_REMINDER_24H=13
BREVO_TPL_CLOSER_REMINDER_1H=14

# Calendly-Links: Setter (Simon, Stage 1) + Closer (Jerome, Klarheitsgespräch).
# Der Closer-Link öffnet sich, wenn ein Lead in "Klarheitsgespräch gebucht" wandert.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/simon-damm/discovery-call
NEXT_PUBLIC_CLOSER_CALENDLY_URL=https://calendly.com/jeromederes-info/discovery-call

# Zeitbasierte Reminder (24h/1h vorher) — noch NICHT scharf. Auf 'true' setzen,
# sobald die Reminder-Templates final sind (Cron läuft dann über scheduled_emails).
REMINDERS_ENABLED=false
# Vercel-Cron-Auth für /api/cron/process-emails (nur nötig wenn Reminder scharf)
CRON_SECRET=
